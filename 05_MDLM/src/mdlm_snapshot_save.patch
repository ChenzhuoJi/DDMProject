+  def snapshots_to_text(self, snapshots, max_length=80):
+    """Convert snapshots from _sample(..., ret_snapshots=True) to readable text.
+
+    Splits token sequence into consecutive runs of normal / mask tokens,
+    decodes normal runs properly (handles BPE subword spacing), and
+    inserts [MASK] markers at mask positions.
+
+    Args:
+      snapshots: List of (t_val, tokens_cpu) pairs.
+      max_length: Max number of characters per line.
+
+    Returns:
+      List of (t_val, text) strings for display.
+    """
+    lines = []
+    for t_val, tokens in snapshots:
+      ids = tokens[0].tolist()  # first sample in batch
+      segments = []
+      buf = []
+      for tid in ids:
+        if tid == self.mask_index:
+          if buf:
+            segments.append(self.tokenizer.decode(buf))
+            buf = []
+          segments.append('[MASK]')
+        else:
+          buf.append(tid)
+      if buf:
+        segments.append(self.tokenizer.decode(buf))
+      text = ' '.join(s for s in segments if s)
+      # Clean up extra spaces
+      text = ' '.join(text.split())
+      if len(text) > max_length:
+        text = text[:max_length] + '...'
+      lines.append((t_val, text))
+    return lines
+
+  def display_snapshots(self, snapshots, max_length=80):
+    """Print a progressive visualization of the diffusion reverse process.
+
+    Args:
+      snapshots: List of (t_val, tokens_cpu) pairs from _sample().
+      max_length: Max characters per line.
+    """
+    lines = self.snapshots_to_text(snapshots, max_length)
+    print('=' * 70)
+    print('Diffusion Reverse Process (t=1.0 → t=0.0)')
+    print('=' * 70)
+    for t_val, text in lines:
+      pct = (1 - t_val) * 100
+      print(f't={t_val:.3f} ({pct:3.0f}% done): {text}')
+    print('=' * 70)
+
+  def save_snapshots_to_file(self, snapshots, filepath, max_length=200):
+    """Save snapshot visualization to a text file.
+
+    Args:
+      snapshots: List of (t_val, tokens_cpu) pairs from _sample().
+      filepath: Path to output text file.
+      max_length: Max characters per line.
+    """
+    lines = self.snapshots_to_text(snapshots, max_length)
+    with open(filepath, 'w') as f:
+      f.write('=' * 70 + '\n')
+      f.write('Diffusion Reverse Process (t=1.0 → t=0.0)\n')
+      f.write('=' * 70 + '\n')
+      for t_val, text in lines:
+        pct = (1 - t_val) * 100
+        f.write(f't={t_val:.3f} ({pct:3.0f}% done): {text}\n')
+      f.write('=' * 70 + '\n')
 
